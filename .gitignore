# Logs
logs
*.log
npm-debug.log*

# Captured local tooling output (lint/build runs) — not source
/build.txt
/eslint-out.txt
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local env files (never commit; CI generates frontend/.env from secrets)
.env
.env.*
!.env.example


# Supabase CLI (local link metadata & versions — regenerated by `supabase link` / `start`)
backend/supabase/.temp/

# Generated SQL bundle for Dashboard paste (see build-dashboard-bundle.sh)
backend/supabase/bundle_apply_in_dashboard.sql

# Licensing — the .env.licensing file contains the build-time public key.
# Safe to keep locally but NOT committed so each dev/CI runs setup-licensing.mjs.
backend/.env.licensing
# Tauri app data license cache (machine-local, tamper-tagged)
license.cache
license.anchor

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
