VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: show the Platform Administration signup card on the signup page.
# Default is hidden (off). Set to "true" to expose the card.
# VITE_ENABLE_PLATFORM_ADMIN_SIGNUP=true

# Solana Sign-In With Wallet (SIWS) — no extra env vars needed.
# The Edge Function is deployed at: $VITE_SUPABASE_URL/functions/v1/solana-auth
# Deploy with: supabase functions deploy solana-auth

# ── Solana on-chain payments (USDC) ──
# Network to settle payments on. devnet for development/demo, mainnet-beta for live.
VITE_SOLANA_CLUSTER=devnet
# Optional custom RPC endpoint. Defaults to the public cluster RPC if unset.
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# USDC SPL mint for the selected cluster. Defaults to Circle's mint per cluster.
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# VITE_SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Treasury wallet (base58) that receives all payments. REQUIRED to enable the
# "Pay with Solana (USDC)" button. Leave empty to hide on-chain payments.
VITE_SOLANA_TREASURY_ADDRESS=

# The solana-pay-verify Edge Function needs matching SERVER-side secrets:
#   supabase secrets set SOLANA_RPC_URL=https://api.devnet.solana.com
#   supabase secrets set SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
#   supabase secrets set SOLANA_TREASURY_ADDRESS=<your-treasury-wallet>
# Deploy with: supabase functions deploy solana-pay-verify

# ── Solana File Record program (optional) ──
# Deploy the Anchor program from backend/solana-programs/sitesurveyor-file-record
# or paste programs/file-record/src/lib.rs into Solana Playground. When set,
# file anchoring uses the program instead of the SPL Memo fallback.
# VITE_SOLANA_FILE_RECORD_PROGRAM_ID=Fg6PaFpoGVkY9jXjCqYj9jXjCqYj9jXjCqYj9jXjCqYj
